# Скопіюйте у .env і заповніть. .env НЕ комітиться (див. .gitignore).

# Токен від @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Облікові дані FSolar
FSOLAR_USERNAME=you@example.com
FSOLAR_PASSWORD=your_password

# Ваш інвертор
FSOLAR_DEVICE_SN=020912004825490362
FSOLAR_DEVICE_TYPE=OG

# Ваш Telegram chat_id (бот підкаже при /start). Лишіть порожнім, щоб дозволити будь-кого.
ALLOWED_CHAT_ID=

# Як часто опитувати FSolar (хв). Хмара оновлюється ~раз на 5 хв.
POLL_INTERVAL_MINUTES=3

# Часовий пояс для відображення часу (IANA-назва). Напр.: Europe/Kyiv, Europe/Warsaw, UTC
TIMEZONE=Europe/Kyiv

# Шлях до бази (у Docker монтується том на /data)
DB_PATH=/data/bot.db
